<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Notification & alarm permissions ──────────────────────────────── -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Required for startActivity() to work when another app is in the foreground.
         All alarm apps (Alarmy, Sleep as Android, etc.) need this. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Android 13+: automatically granted, enables setExactAndAllowWhileIdle() for pre-alarms. -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Android 12: user must grant this manually; we prompt in MainActivity if needed.
         setAlarmClock() is always exempt regardless of this permission. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"
        tools:ignore="ExactAlarm" />

    <!-- Foreground services. All our services are user-initiated session holders
         (routine/focus timers, pinned alarm notifications) — none of the specific
         FGS types fit, so each declares specialUse with an explanatory subtype
         property (see the <service> tags). Google requires a Play Console
         declaration for specialUse; the subtype values below are written for it. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Boot receiver -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Focus mode: toggle Do Not Disturb during sessions. Declaring this is what
         makes FocusForce+ appear in Android's "Do Not Disturb access" list — the
         actual grant still happens there, by the user. -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <!-- App blocker: measure per-app usage for daily limits. Special-access permission,
         granted by the user in system settings after an in-app prominent disclosure. -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Package visibility: only apps with a launcher entry (the blockable ones).
         Deliberately NOT QUERY_ALL_PACKAGES — see .claude/PLAY_STORE_COMPLIANCE.md,
         Golden Rule #6. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.HOME" />
        </intent>
    </queries>

    <application
        android:name=".FocusForcePlusApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FocusForce">

        <!-- Full-screen alarm activity — shown over the lock screen when a routine fires -->
        <activity
            android:name=".ui.alarm.RoutineAlarmActivity"
            android:exported="false"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.FocusForce" />

        <!-- Full-screen alarm activity for scheduled todos -->
        <activity
            android:name=".ui.alarm.TodoAlarmActivity"
            android:exported="false"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.FocusForce" />

        <!-- Main activity — also the target for alarm full-screen intents -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.FocusForce.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Short-lived service that starts RoutineAlarmActivity from background -->
        <service
            android:name=".service.AlarmLaunchService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Launches the full-screen routine alarm the user scheduled; alive for under a second." />
        </service>

        <!-- Foreground service that keeps the process alive during a routine session -->
        <service
            android:name=".service.RoutineForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Keeps the user-started routine timer running with a live countdown notification until the routine ends." />
        </service>

        <!-- Receives scheduled routine alarms (main alarm + snooze) -->
        <receiver
            android:name=".service.RoutineAlarmReceiver"
            android:exported="false" />

        <!-- Receives the 15-minute pre-alarm and shows a reminder notification -->
        <receiver
            android:name=".service.RoutinePreAlarmReceiver"
            android:exported="false" />

        <!-- Handles "Snooze" actions from the pre-alarm notification -->
        <receiver
            android:name=".service.RoutineRescheduleReceiver"
            android:exported="false" />

        <!-- Handles "Dismiss" taps from alarm and snooze notifications -->
        <receiver
            android:name=".service.RoutineDismissReceiver"
            android:exported="false" />

        <!-- Handles "Done" action from the active-routine foreground notification -->
        <receiver
            android:name=".service.RoutineSessionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.focusforceplus.app.SESSION_COMPLETE_TASK" />
            </intent-filter>
        </receiver>

        <!-- Restores alarms after device reboot -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Fires when a scheduled todo reaches its due time -->
        <receiver
            android:name=".service.TodoAlarmReceiver"
            android:exported="false" />

        <!-- Handles "Snooze" actions from todo alarm notifications -->
        <receiver
            android:name=".service.TodoSnoozeReceiver"
            android:exported="false" />

        <!-- Handles "Done" and "Dismiss" actions from todo alarm notifications -->
        <receiver
            android:name=".service.TodoDismissReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.focusforceplus.app.TODO_DONE" />
                <action android:name="com.focusforceplus.app.TODO_DISMISS" />
            </intent-filter>
        </receiver>

        <!-- Fires 3x daily (8:00, 14:00, 20:00) to show todo digest notifications -->
        <receiver
            android:name=".service.TodoDigestReceiver"
            android:exported="false" />

        <!-- Foreground service that keeps the alarm notification non-dismissable (High + Medium) -->
        <service
            android:name=".service.TodoAlarmForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Pins the alarm notification of a due todo the user scheduled, until the user acts on it." />
        </service>

        <!-- Foreground service that keeps the overdue-todos notification non-dismissable -->
        <service
            android:name=".service.TodoReminderForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Pins the overdue-todo summary notification the user opted into, until the todos are handled." />
        </service>

        <!-- App blocker: detects which app is in the foreground (window state changes
             only, no content access) and shows the blocked screen. Config is minimal
             by design — see res/xml/accessibility_service_config.xml. -->
        <service
            android:name=".service.AppBlockerAccessibilityService"
            android:exported="false"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Full-screen cover for blocked apps. Isolated task, never in recents,
             disappears once left — the user can always reach Home. -->
        <activity
            android:name=".ui.screens.blocker.BlockedAppActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:noHistory="true"
            android:taskAffinity=""
            android:theme="@style/Theme.FocusForce" />

        <!-- Owns a running focus session: countdown, ongoing notification, DND -->
        <service
            android:name=".service.FocusForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Runs the user-started focus session countdown and restores Do Not Disturb when it ends." />
        </service>

        <!-- Fires at a focus session's scheduled time (reminder, no auto-start) -->
        <receiver
            android:name=".service.FocusAlarmReceiver"
            android:exported="false" />

        <!-- Handles "End session" / "Start now" actions from focus notifications -->
        <receiver
            android:name=".service.FocusSessionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.focusforceplus.app.FOCUS_END_SESSION" />
                <action android:name="com.focusforceplus.app.FOCUS_START_SCHEDULED" />
            </intent-filter>
        </receiver>

        <!-- Quick-settings tile: start a 25-min quick focus with one tap.
             exported=true is required for system binding; the BIND permission
             restricts callers to the system. -->
        <service
            android:name=".service.FocusTileService"
            android:exported="true"
            android:icon="@drawable/ic_tile_focus"
            android:label="Quick focus"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

    </application>

</manifest>
