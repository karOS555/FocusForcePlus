<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude the settings DataStore so the onboarding/permission walkthrough
             re-appears on a fresh install (system permission grants are never backed
             up anyway, so the user must go through setup again). Room user data
             (routines, todos, rules, sessions) is still backed up. -->
        <exclude domain="file" path="datastore/settings.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/settings.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
